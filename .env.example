# ── Backend ──────────────────────────────────────────────────────────────────
# Copy relevant vars to backend/.env (or set them in your hosting dashboard)

# Flask
SECRET_KEY=change-me-in-production
FLASK_APP=run.py
FLASK_ENV=development

# Database
# Dev default: SQLite (no setup needed)
# Prod: paste the connection string from Neon / Render / Supabase
DATABASE_URL=postgresql://user:password@host:5432/taskflow

# CORS — set to your frontend URL in production e.g. https://taskflow.vercel.app
# Leave as * for local dev
CORS_ORIGINS=*

# OpenAI (optional — app works without it using heuristic fallback)
# OPENAI_API_KEY=sk-...


# ── Frontend ──────────────────────────────────────────────────────────────────
# Copy to frontend/.env.local

# Dev: leave unset — the CRA proxy handles it (see package.json "proxy")
# Prod: set to your deployed backend URL
# REACT_APP_API_BASE=https://taskflow-api.onrender.com/api
